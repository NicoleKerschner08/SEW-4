<Window x:Class="_21_calcWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_21_calcWPF"
        mc:Ignorable="d"
        Title="Rechnen" Height="250" Width="320">
    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal">
            <StackPanel Width="180">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="Zahl 1" Width="60" VerticalAlignment="Center"/>
                    <TextBox Width="80" Text="{Binding number1}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="Zahl 2" Width="60" VerticalAlignment="Center"/>
                    <TextBox Width="80" Text="{Binding number2}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="Ergebnis" Width="60" VerticalAlignment="Center"/>
                    <TextBox Width="80" IsReadOnly="True" Text="{Binding result}" Foreground="{Binding brush}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Margin="10,0,0,0">
                <Button Content="Addition" Width="90" Margin="0,2" Command="{Binding cmdButtonClick}" CommandParameter="addition"/>
                <Button Content="Subtraktion" Width="90" Margin="0,2" Command="{Binding cmdButtonClick}" CommandParameter="subtraktion"/>
                <Button Content="Multipl." Width="90" Margin="0,2" Command="{Binding cmdButtonClick}" CommandParameter="multiplikation"/>
                <Button Content="Divis." Width="90" Margin="0,2" Command="{Binding cmdButtonClick}" CommandParameter="division"/>
                <Button Content="Reset" Width="90" Margin="0,2" Command="{Binding cmdButtonClick}" CommandParameter="reset" />
            </StackPanel>
        </StackPanel>
        <TextBlock Text="Status" Margin="0,10,0,0"/>
        <TextBox Height="40" IsReadOnly="True" Text="{Binding status}"/>
    </StackPanel>
</Window>

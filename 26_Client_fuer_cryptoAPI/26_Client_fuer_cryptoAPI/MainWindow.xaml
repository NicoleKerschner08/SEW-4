<Window x:Class="_26_Client_fuer_cryptoAPI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_26_Client_fuer_cryptoAPI"
        mc:Ignorable="d"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Crypto Price Viewer" Height="450" Width="800">
    <StackPanel>
        <TextBox x:Name="UrlTextBox" Margin="0,8,0,0" FontSize="16" Text="https://localhost:7201"></TextBox>
        <Button Content="Daten laden" Margin="0,8,0,0" FontSize="16" Click="loadData_click"></Button>
        <Label Content="Anzahl der Kurswerte:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16" />
        <TextBlock x:Name="tbx_countValues" Width="300" HorizontalAlignment="Left" FontSize="16" FontWeight="Bold" Margin="10,0,0,0" />
        <StackPanel>
            <!-- Liniendiagramm -->
            <lvc:CartesianChart x:Name="PriceChart" Height="243" Margin="10" Width="714">
                <lvc:CartesianChart.Series>
                    <lvc:LineSeries Title="Kursverlauf" Values="{Binding PriceValues}" PointGeometrySize="5" />
                </lvc:CartesianChart.Series>
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Title="Zeit" Labels="{Binding TimeLabels}" />
                </lvc:CartesianChart.AxisX>
                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Title="Preis (EUR)" />
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>
        </StackPanel>
    </StackPanel>
</Window>

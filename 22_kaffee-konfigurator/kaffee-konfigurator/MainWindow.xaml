<Window x:Class="kaffee_konfigurator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kaffee_konfigurator"
        mc:Ignorable="d"
        Title="MainWindow" Height="200" Width="300">
    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Größe:" Margin="5"/>
            <ComboBox ItemsSource="{Binding Sizes}" SelectedItem="{Binding SelectedSize, Mode=TwoWay}"  Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Zusätze:" Margin="5"/>
            <CheckBox Content="Extra Schuss Espresso" IsChecked="{Binding IsChecked}" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Anzeige:" Margin="5"/>
            <TextBlock Margin="5" Width="100" Text="{Binding price}"/>
        </StackPanel>
        <Button Command="{Binding cmdButtonClick}" Content="Bestellen" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" Width="100"/>
    </StackPanel>
</Window>

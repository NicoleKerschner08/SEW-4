<Window x:Class="_20_SimpleExample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_20_SimpleExample"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="MyConverter"></BooleanToVisibilityConverter>
    </Window.Resources>
    <StackPanel>
        <TextBox Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}" />
        <TextBox Text="{Binding Number}" />

        <Slider x:Name="MySlider" Minimum="0" Maximum="100"></Slider>
        <Rectangle Fill="Red" Width="{Binding ElementName=MySlider, Path=Value}" Height="{Binding ElementName=MySlider, Path=Value}"></Rectangle>

        <CheckBox x:Name="VisibilityCheckBox">VisibilityCheckbox</CheckBox>
        <Rectangle Fill="Blue" Width="100" Height="100" Visibility="{Binding ElementName=VisibilityCheckBox, Path=IsChecked, Converter={StaticResource MyConverter}}"></Rectangle>
    </StackPanel>
</Window>

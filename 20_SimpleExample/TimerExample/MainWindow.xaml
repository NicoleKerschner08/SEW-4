<Window x:Class="TimerExample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimerExample"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <TextBox Text="{Binding Number}"></TextBox>
        <Button Command="{Binding CmdButtonClick}" CommandParameter="value0">Reset</Button>
        <Button Command="{Binding CmdButtonClick}" CommandParameter="value1000">1000</Button>
    </StackPanel>
</Window>

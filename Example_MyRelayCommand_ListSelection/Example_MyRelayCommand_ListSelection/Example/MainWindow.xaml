<Window x:Class="Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <Label Content="{Binding DisplayText}" Margin="10"></Label>
        <Button Margin="10" Command="{Binding CommandOK}">OK</Button>
        <Button Margin="10" Command="{Binding CommandCancel}">Cancel</Button>

        <TextBox Text="{Binding ElementName=MyList, Path=SelectedItem.EMail}"></TextBox>
        
        <ListView x:Name="MyList" Margin="10" ItemsSource="{Binding People}" SelectedItem="{Binding SelectedPerson}">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="SelectionChanged">
                    <b:InvokeCommandAction Command="{Binding ListCommand}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>
        </ListView>
    </StackPanel>
</Window>

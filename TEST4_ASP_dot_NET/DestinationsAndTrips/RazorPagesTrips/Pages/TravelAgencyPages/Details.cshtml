@page
@model RazorPagesTrips.Pages.TravelAgencyPages.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Travel Agency</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TravelAgency.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TravelAgency.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TravelAgency.Country)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TravelAgency.Country)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TravelAgency.Rating)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TravelAgency.Rating)
        </dd>
        <dd class = "col-sm-10">
            @if(Model.TravelAgency.Rating > 4)
            {
                <text>Top Rating!</text>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.TravelAgency.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a> |
    <a asp-page="./Delete" asp-route-id="@Model.TravelAgency.Id">Delete</a>
</div>
